{
  "name": "portfolio-2025-2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "dev:api": "vercel dev --listen 3000",
    "dev:full": "vercel dev --listen 3000",
    "build": "prisma generate && tsc -b && vite build",
    "db:migrate": "tsx scripts/migrate-deploy.ts",
    "db:baseline": "dotenv -e .env -e .env.local -- tsx scripts/baseline-migrations.ts",
    "db:sync": "prisma db push --accept-data-loss",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "db:push": "dotenv -e .env -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env -e .env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env -e .env.local -- prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.11",
    "@clerk/clerk-react": "^5.49.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/react": "^10.55.0",
    "dotenv": "^16.6.1",
    "framer-motion": "^12.40.0",
    "gsap": "^3.13.0",
    "howler": "^2.2.4",
    "lenis": "^1.3.11",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "three": "^0.181.0"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.3.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/howler": "^2.2.12",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "^0.181.0",
    "@vercel/node": "^5.8.8",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv-cli": "^7.4.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.22.3",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-glsl": "^1.5.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
