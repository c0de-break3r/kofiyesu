generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ChatConversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id")
  title     String   @default("New chat")
  messages  Json     @default("[]")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId, updatedAt(sort: Desc)])
  @@map("chat_conversations")
}

model ContactInquiry {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inquiryType String    @map("inquiry_type")
  message     String
  needsAdmin  Boolean   @default(false) @map("needs_admin")
  status      String    @default("new")
  adminNotes  String?   @map("admin_notes")
  replyDraft  String?   @map("reply_draft")
  adminReply  String?   @map("admin_reply")
  adminReplyAt DateTime? @map("admin_reply_at") @db.Timestamptz(6)
  conversationId String? @map("conversation_id") @db.Uuid
  userEmail   String?   @map("user_email")
  userId      String?   @map("user_id")
  userName    String?   @map("user_name")
  intake      Json?
  reviewedAt  DateTime? @map("reviewed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  payments    Payment[]

  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("contact_inquiries")
}

model Payment {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inquiryId          String?   @map("inquiry_id") @db.Uuid
  inquiry            ContactInquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  userId             String?   @map("user_id")
  userEmail          String?   @map("user_email")
  userName           String?   @map("user_name")
  title              String
  description        String?
  amountGhs          Decimal   @map("amount_ghs") @db.Decimal(12, 2)
  currency           String    @default("GHS")
  status             String    @default("pending")
  packageId          String?   @map("package_id")
  paystackReference  String?   @unique @map("paystack_reference")
  paystackAccessCode String?   @map("paystack_access_code")
  paidAt             DateTime? @map("paid_at") @db.Timestamptz(6)
  metadata           Json?
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([userId, status])
  @@index([inquiryId])
  @@index([status, createdAt(sort: Desc)])
  @@map("payments")
}

model SiteFeature {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String        @unique
  label     String
  sortOrder Int           @default(0) @map("sort_order")
  published Boolean       @default(true)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  projects  SiteProject[]

  @@index([sortOrder, createdAt])
  @@map("site_features")
}

model SiteProject {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug         String   @unique
  title        String
  theme        String   @default("dark")
  categoryId   String?  @map("category_id") @db.Uuid
  category     SiteFeature? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  techStack    Json     @default("[]") @map("tech_stack")
  description  String?
  thumbnailUrl String?  @map("thumbnail_url")
  previewVideoUrl String? @map("preview_video_url")
  showcaseVideoUrl String? @map("showcase_video_url")
  showcaseVideoCaption String? @map("showcase_video_caption")
  liveUrl      String?  @map("live_url")
  sourceUrl    String?  @map("source_url")
  videoBorder  Boolean  @default(false) @map("video_border")
  components   Json     @default("[]")
  sortOrder    Int      @default(0) @map("sort_order")
  published    Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([sortOrder, createdAt])
  @@index([categoryId])
  @@map("site_projects")
}

model SiteAbout {
  id          String   @id @default("default")
  displayName String?  @map("display_name")
  jobTitle    String?  @map("job_title")
  aboutIntro  String?  @map("about_intro")
  aboutTagline String? @map("about_tagline")
  location    String?
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_about")
}
