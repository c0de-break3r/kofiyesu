# Clerk (required for client sign-in + chat + admin)
VITE_CLERK_PUBLISHABLE_KEY="pk_live_Y2xlcmsua29maXllc3UuY29tJA"

# Comma-separated Clerk user IDs allowed to access /admin (copy from Clerk Dashboard → Users)
VITE_CLERK_ADMIN_USER_IDS="user_3D0Z0fhezYDoIkCxch5Ci4jy9JF"

# Supabase (optional — inquiry logging for admin dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-ke
# AI chat (server-only — never use VITE_ prefix). Set on Vercel → Project → Environment Variables.
# Local: use `npm run dev:api` (not plain `npm run dev`) so /api/chat runs with this key.
GEMINI_API_KEY=
# optional: gemini-2.0-flash (default), gemini-2.5-flash-preview, etc.
# GEMINI_MODEL=gemini-2.0-flash
# GOOGLE_GENERATIVE_AI_API_KEY=  # alias for GEMINI_API_KEY
# OPENAI_API_KEY=                # optional fallback
