# Clerk (required for client sign-in + chat + admin)
VITE_CLERK_PUBLISHABLE_KEY="pk_live_Y2xlcmsua29maXllc3UuY29tJA"

# Comma-separated Clerk user IDs allowed to manage site content (Clerk Dashboard → Users)
VITE_CLERK_ADMIN_USER_IDS="user_3D0Z0fhezYDoIkCxch5Ci4jy9JF"

# Supabase (inquiry logging + CMS tables site_projects / site_about)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Duplicate on Vercel for serverless /api routes (recommended):
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
# Server-only (Vercel env — admin API writes)
SUPABASE_SERVICE_ROLE_KEY=
CLERK_SECRET_KEY=
# Same admin IDs as above (server-side /api/admin auth)
CLERK_ADMIN_USER_IDS=

# Cloudinary (unsigned upload preset for admin project thumbnails & assets)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# optional folder, e.g. kofiyesu/portfolio
# VITE_CLOUDINARY_FOLDER=

# AI chat (server-only — never use VITE_ prefix). Set on Vercel → Project → Environment Variables.
# Local: use `npm run dev:api` (not plain `npm run dev`) so /api/chat runs with this key.
GEMINI_API_KEY=
# optional override (default: gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview
# GOOGLE_GENERATIVE_AI_API_KEY=  # alias for GEMINI_API_KEY
# OPENAI_API_KEY=                # optional fallback
