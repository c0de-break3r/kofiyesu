# Clerk — sign-in, chat, admin CMS (slide-over panel)
VITE_CLERK_PUBLISHABLE_KEY="pk_live_..."
# Comma-separated Clerk user IDs allowed to open admin CMS (Dashboard → Users → copy user_…)
VITE_CLERK_ADMIN_USER_IDS="user_..."
CLERK_SECRET_KEY="sk_live_..."
# Same IDs as above (required for /api/admin/* on Vercel)
CLERK_ADMIN_USER_IDS="user_..."

# Neon Postgres (Prisma) — pooled connection string from Neon dashboard
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Cloudinary (admin uploads — preset must allow image + video)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# VITE_CLOUDINARY_FOLDER=portfolio

# AI chat (server-only)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3-flash-preview

# Urgent inquiry email (Resend)
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=hello@kofiyesu.com
# ADMIN_NOTIFY_FROM="Kofiyesu <onboarding@resend.dev>"

# Paystack (GHS — card & Mobile Money)
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=
# Public site URL for payment callbacks (defaults to https://kofiyesu.com)
SITE_URL=https://kofiyesu.com

# WhatsApp (country code, no + — e.g. 233XXXXXXXXX)
VITE_WHATSAPP_NUMBER=
